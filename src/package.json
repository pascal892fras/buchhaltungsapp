{
  "name": "buchhaltung-app",
  "version": "1.0.0",
  "description": "Buchhaltungs- und Rechnungs-App für Kleingewerbetreibende",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "de.kleingewerbe.buchhaltung",
    "productName": "Buchhaltung",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerLanguages": ["de_DE"],
      "language": "1031"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.exe"
    },
    "files": ["main.js", "scr/**/*", "package.json"],
    "directories": { "output": "dist" }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
